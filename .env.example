# ByteHR AI — Environment Configuration
# Copy this file to .env and fill in the values before starting the stack.

# ─── Database ───────────────────────────────────────────────────────────────
DB_NAME=bytehr
DB_USERNAME=bytehr
DB_PASSWORD=changeme_strong_password
DB_PORT=5432

# ─── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen3:14b
OLLAMA_TIMEOUT=120

# ─── SharePoint / Microsoft Graph ───────────────────────────────────────────
# Obtain these from your Azure App Registration.
# Required permissions: Sites.Read.All, Files.Read.All (Application)
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_CLIENT_ID=your-azure-app-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-app-client-secret
SHAREPOINT_SITE_ID=your-sharepoint-site-id
SHAREPOINT_DRIVE_ID=your-sharepoint-drive-id
SHAREPOINT_SYNC_ENABLED=true

# ─── Microsoft Teams Bot ────────────────────────────────────────────────────
# Obtain from Azure Bot Service registration.
TEAMS_APP_ID=your-teams-bot-app-id
TEAMS_APP_PASSWORD=your-teams-bot-app-password

# ─── API Server ─────────────────────────────────────────────────────────────
SERVER_PORT=8080
FRONTEND_PORT=4200
API_URL=http://localhost:8080

# ─── Vector Search Tuning ────────────────────────────────────────────────────
VECTOR_SEARCH_TOP_K=5
VECTOR_SEARCH_MIN_SCORE=0.5
VECTOR_SEARCH_CONFIDENCE_THRESHOLD=0.6

# ─── Document Processing ─────────────────────────────────────────────────────
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=200
