{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "packageName": "com.bytehr.teams",
  "developer": {
    "name": "ByteHR Team",
    "websiteUrl": "https://bytehr.example.com",
    "privacyUrl": "https://bytehr.example.com/privacy",
    "termsOfUseUrl": "https://bytehr.example.com/terms"
  },
  "name": {
    "short": "ByteHR AI",
    "full": "ByteHR AI — HR Assistant"
  },
  "description": {
    "short": "AI-powered HR Assistant for employees.",
    "full": "ByteHR AI answers your HR questions in Albanian, Serbian and English using official company policies from SharePoint. No need to search documents manually — just ask."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "bots": [
    {
      "botId": "${{TEAMS_APP_ID}}",
      "scopes": ["personal"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [],
  "webApplicationInfo": {
    "id": "${{TEAMS_APP_ID}}",
    "resource": "api://bytehr.example.com/${{TEAMS_APP_ID}}"
  }
}
